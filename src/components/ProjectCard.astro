---
import Tag from './Tag.astro';

interface Props {
  name: string;
  state: string;
  summary: string;
  labels: string[];
  href: string;
  external?: boolean;
  first?: boolean;
}
const { name, state, summary, labels, href, external = false, first = false } = Astro.props;
---
<a href={href} class:list={["grid grid-cols-[200px_1fr] max-md:grid-cols-1 gap-8 max-md:gap-2 py-7 border-b border-border-subtle no-underline group", first && "pt-0"]} target={external ? "_blank" : undefined} rel={external ? "noopener noreferrer" : undefined}>
  <div class="flex flex-col gap-1.5">
    <span class="text-lg font-semibold tracking-tight border-b border-transparent group-hover:border-(--color-text) transition-colors w-fit">{name}</span>
    <span class="font-mono text-[0.6875rem] uppercase tracking-[0.08em] text-text-muted">{state}</span>
  </div>
  <div>
    <p class="text-text-secondary text-[0.9375rem] mb-3">{summary}</p>
    <div class="flex gap-1.5 flex-wrap">
      {labels.map(label => <Tag label={label} />)}
    </div>
  </div>
</a>
